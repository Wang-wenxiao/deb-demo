{
  "name": "trtc-terminal",
  "version": "1.0.0",
  "description": "TRTC Terminal App",
  "main": "main.js",
  "author": "Tencent TRTC",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:deb": "npx electron-builder --linux deb --arm64",
    "dist:amd64": "npx electron-builder --linux deb --x64"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.tencent.trtc-terminal",
    "productName": "TRTC Terminal",
    "copyright": "Copyright 2026 Tencent",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": ["main.js", "preload.js"],
    "linux": {
      "target": [{"target": "deb", "arch": ["arm64"]}],
      "icon": "icons/icon.png",
      "category": "Utility",
      "desktop": {
        "Name": "TRTC Terminal",
        "Comment": "TRTC Audio Video System",
        "Categories": "Utility;Network;",
        "StartupWMClass": "trtc-terminal"
      },
      "deb": {
        "depends": [
          "libgtk-3-0", "libnotify4", "libnss3", "libxss1",
          "libxtst6", "xdg-utils", "libatspi2.0-0", "libsecret-1-0"
        ]
      }
    }
  }
}